# Email configurations for sending alerts
# Copy this file, rename it to '.env', and fill in your details.
# DO NOT commit your actual '.env' file to GitHub!

# Gmail SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# The email address that will send the alerts
SENDER_EMAIL=your_email@gmail.com

# Your Gmail App Password (16 characters, e.g., 'abcd efgh ijkl mnop')
# NOT your regular Google Account password!
SENDER_PASSWORD=pekf uhgh pczi eqmw

# The email address that will receive the alerts (can be the same as sender)
RECEIVER_EMAIL=your_receiver_email@gmail.com

# Set to 'True' to enable email sending, 'False' to print alerts to terminal only
ENABLE_EMAIL=False
